{
  "version": 2,
  "builds": [
    {
      "src": "api/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "functions": {
    "api/bi-data.ts": { "maxDuration": 60 },
    "api/bi-data-batch.ts": { "maxDuration": 60 },
    "api/get-metadata.ts": { "maxDuration": 30 },
    "api/save-metadata.ts": { "maxDuration": 30 }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}