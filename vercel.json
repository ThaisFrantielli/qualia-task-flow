{
  "version": 2,
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "devCommand": "vite --port $PORT",
  "functions": {
    "api/bi-data.ts": { "maxDuration": 60 },
    "api/bi-data-batch.ts": { "maxDuration": 60 },
    "api/get-metadata.ts": { "maxDuration": 30 },
    "api/save-metadata.ts": { "maxDuration": 30 }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/((?!api|assets|favicon\\.ico|robots\\.txt|@vite|@react-refresh|node_modules|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}